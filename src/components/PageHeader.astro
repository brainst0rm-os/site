---
interface Props {
	eyebrow?: string;
	title: string;
	lede?: string;
	meta?: string[];
}

const { eyebrow, title, lede, meta } = Astro.props;
---

<header class="page-header">
	{
		eyebrow && (
			<p class="eyebrow">
				<span class="diamond" aria-hidden="true">
					◇
				</span>
				{eyebrow}
			</p>
		)
	}
	<h1 class="page-title">{title}</h1>
	{lede && <p class="page-lede">{lede}</p>}
	{
		meta && meta.length > 0 && (
			<p class="page-meta mono">
				{meta.map((item, i) => (
					<>
						{i > 0 && (
							<span class="sep" aria-hidden="true">
								·
							</span>
						)}
						<span>{item}</span>
					</>
				))}
			</p>
		)
	}
</header>

<style>
	.page-header {
		display: flex;
		flex-direction: column;
		gap: var(--space-3);
		margin-bottom: var(--space-8);
		padding-bottom: var(--space-6);
		border-bottom: 1px solid var(--hairline);
		max-width: 60ch;
	}
	.eyebrow {
		display: inline-flex;
		align-items: center;
		gap: var(--space-2);
		color: var(--fog-1);
	}
	.diamond {
		color: var(--cyan-glow);
		font-size: 0.9em;
		line-height: 1;
	}
	.page-title {
		font-size: clamp(2rem, 3vw + 1rem, 3rem);
		font-weight: 500;
		letter-spacing: var(--tracking-hero);
		line-height: var(--leading-tight);
		text-wrap: balance;
	}
	.page-lede {
		font-size: var(--text-lg);
		line-height: var(--leading-snug);
		color: var(--fog-3);
		max-width: 60ch;
		text-wrap: balance;
	}
	.page-meta {
		display: inline-flex;
		gap: 10px;
		font-size: var(--text-mono);
		color: var(--fog-1);
		text-transform: uppercase;
		letter-spacing: var(--tracking-eyebrow);
		margin-top: var(--space-3);
		flex-wrap: wrap;
	}
	.sep {
		color: var(--fog-1);
	}
</style>
